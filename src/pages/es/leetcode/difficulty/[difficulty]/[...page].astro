---
import Layout from "../../../../../layouts/Layout.astro";
import Pagination from "../../../../../components/Pagination.astro";
import LeetCodeFilters from "../../../../../components/LeetCodeFilters.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import type { GetStaticPaths, Page } from "astro";

export const getStaticPaths = (async ({ paginate }) => {
    const allSolutions = await getCollection("leetcode");
    const difficulties = ["Easy", "Medium", "Hard"];

    return difficulties.flatMap((difficulty) => {
        const filteredSolutions = allSolutions
            .filter(
                (s) =>
                    s.id.startsWith("es/") && s.data.difficulty === difficulty,
            )
            .sort((a, b) => {
                // Extract number from ID (e.g. es/0001-two-sum.md -> 1)
                const getNum = (id: string) => {
                    const match = id.split("/")[1].match(/^(\d+)/);
                    return match ? parseInt(match[1]) : 0;
                };
                return getNum(a.id) - getNum(b.id);
            });

        return paginate(filteredSolutions, {
            params: { difficulty: difficulty.toLowerCase() },
            pageSize: 20,
            props: { difficulty },
        });
    });
}) satisfies GetStaticPaths;

interface Props {
    page: Page<CollectionEntry<"leetcode">>;
    difficulty: "Easy" | "Medium" | "Hard";
}

const { page, difficulty } = Astro.props;

const difficultyColor = {
    Easy: "text-emerald-500 bg-emerald-50 dark:bg-emerald-950",
    Medium: "text-amber-500 bg-amber-50 dark:bg-amber-950",
    Hard: "text-rose-500 bg-rose-50 dark:bg-rose-950",
};

function getSlug(id: string) {
    return id.replace(/^es\//, "").replace(/\.(md|mdx)$/, "");
}
---

<Layout
    title={`${difficulty} LeetCode Solutions — eddn.dev`}
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    hreflangs={[
        {
            lang: "en",
            href: `/leetcode/difficulty/${difficulty.toLowerCase()}`,
        },
    ]}
>
    <main class="max-w-7xl mx-auto px-6 py-24">
        <header class="mb-16">
            <h1
                class="text-6xl sm:text-8xl font-black tracking-tighter text-slate-900 dark:text-white leading-[0.85] mb-8"
            >
                SOLUCIONES <br />
                <span
                    class="text-brand-500 underline decoration-brand-100 decoration-8 underline-offset-8"
                    >LEETCODE.</span
                >
            </h1>
            <p class="text-xl text-slate-600 dark:text-slate-400 font-light max-w-2xl">
                Soluciones y análisis de dificultad {difficulty}.
            </p>
        </header>

        <LeetCodeFilters currentFilter={difficulty} baseUrl="/es/leetcode" />

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-slate-200 dark:border-slate-800">
                        <th
                            class="py-4 font-mono text-xs uppercase tracking-widest text-slate-400"
                            >Problema</th
                        >
                        <th
                            class="py-4 font-mono text-xs uppercase tracking-widest text-slate-400"
                            >Dificultad</th
                        >
                        <th
                            class="py-4 font-mono text-xs uppercase tracking-widest text-slate-400"
                            >Complejidad</th
                        >
                        <th
                            class="py-4 font-mono text-xs uppercase tracking-widest text-slate-400"
                            >Fecha</th
                        >
                    </tr>
                </thead>
                <tbody>
                    {
                        page.data.map((solution) => (
                            <tr class="border-b border-slate-100 dark:border-slate-800 group hover:bg-brand-50/30 dark:hover:bg-brand-950/30 transition-colors">
                                <td class="py-6">
                                    <a
                                        href={`/es/leetcode/${getSlug(solution.id)}`}
                                        class="font-bold text-slate-900 dark:text-slate-100 group-hover:text-brand-500 transition-colors"
                                    >
                                        <span
                                            transition:name={`title-${solution.id}`}
                                        >
                                            {solution.data.title}
                                        </span>
                                    </a>
                                </td>
                                <td class="py-6">
                                    <span
                                        transition:name={`difficulty-${solution.id}`}
                                        class={`text-xs font-bold px-2.5 py-1 rounded-full ${difficultyColor[solution.data.difficulty]}`}
                                    >
                                        {solution.data.difficulty}
                                    </span>
                                </td>
                                <td class="py-6 text-sm font-mono text-slate-500">
                                    {solution.data.complexity ? (
                                        <span>
                                            T: {solution.data.complexity.time} /
                                            S: {solution.data.complexity.space}
                                        </span>
                                    ) : (
                                        <span class="text-slate-300 dark:text-slate-600">N/A</span>
                                    )}
                                </td>
                                <td class="py-6 text-sm font-mono text-slate-400">
                                    {solution.data.pubDate.toLocaleDateString(
                                        "es-ES",
                                        {
                                            year: "numeric",
                                            month: "short",
                                        },
                                    )}
                                </td>
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>

        <Pagination page={page} />
    </main>
</Layout>
